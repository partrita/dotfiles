# --- 자동 시작 프로그램 ---
# i3 시작 시 실행할 프로그램들
exec --no-startup-id nitrogen --restore # 배경화면 설정 (nitrogen 사용 시)
exec --no-startup-id picom --config ~/.config/picom/picom.conf # 컴포지터 (투명도 등)
# exec --no-startup-id nm-applet # 네트워크 매니저 애플릿
